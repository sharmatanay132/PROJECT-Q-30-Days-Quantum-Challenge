   "source": [
    "import random\n",
    "classical = [random.randint(0, 1) for _ in range(20)]\n",
    "print(\"Classical Random Numbers\")\n",
    "print(classical)\n",
    "zeros = classical.count(0)\n",
    "ones = classical.count(1)\n",
    "print(\"Number of zeros:\", zeros)\n",
    "print(\"Number of ones:\", ones)"
   ]
